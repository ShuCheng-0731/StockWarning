DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
# Optional initial notification channel.
# You can also set it later inside Discord via /settings_set_channel
# DISCORD_CHANNEL_ID=123456789012345678

# Optional: set this for faster slash-command sync in one server.
# DISCORD_GUILD_ID=123456789012345678

# Poll intervals (seconds)
STOCK_CHECK_INTERVAL_SEC=300
ECONOMY_CHECK_INTERVAL_SEC=21600
MANUAL_CHECK_TIMEOUT_SEC=45

# Optional custom paths
# WATCHLIST_PATH=watchlist.json
# STATE_PATH=state.json
# RUNTIME_CONFIG_PATH=config.json

# Optional custom source URL for economy signal page
# ECONOMY_SOURCE_URL=https://index.ndc.gov.tw/n/zh_twr

# Optional API endpoint used to detect latest economy signal period
# ECONOMY_API_URL=https://index.ndc.gov.tw/n/json/lightscore
