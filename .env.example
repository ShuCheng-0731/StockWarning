DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Optional: set this for faster slash-command sync in one server.
# DISCORD_GUILD_ID=123456789012345678

# Scheduler tick (seconds): how often bot checks which users are due.
POLL_TICK_SEC=60

# Per-user default intervals (seconds) for new users.
STOCK_CHECK_INTERVAL_SEC=600
ECONOMY_CHECK_INTERVAL_SEC=43200

# Timeout for each manual /check_now item.
MANUAL_CHECK_TIMEOUT_SEC=45

# Per-account persistent data file.
# USER_DATA_PATH=user_data.json

# Economy official page (for message reference)
# ECONOMY_SOURCE_URL=https://index.ndc.gov.tw/n/zh_twr
