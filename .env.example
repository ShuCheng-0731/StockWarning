DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Scheduler tick (seconds): how often bot checks which users are due.
POLL_TICK_SEC=60

# Per-user default intervals (seconds) for new users.
STOCK_CHECK_INTERVAL_SEC=600

# Timeout for each manual /check_now item.
MANUAL_CHECK_TIMEOUT_SEC=45

# Per-account persistent data file.
# USER_DATA_PATH=user_data.json

# Economy official page (bot will read its JSON source first)
# ECONOMY_SOURCE_URL=https://index.ndc.gov.tw/n/zh_tw

# Optional fixed ZIP source (fallback/override)
# ECONOMY_ZIP_URL=https://ws.ndc.gov.tw/Download.ashx?u=...&n=...
